{
  "name": "yakquest",
  "private": true,
  "workspaces": [
    "shared",
    "web",
    "mobile"
  ],
  "overrides": {
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.0",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "scripts": {
    "typecheck": "npm run typecheck -w @yakquest/shared && npm run typecheck -w web && npm run typecheck -w mobile",
    "typecheck:shared": "npm run typecheck -w @yakquest/shared",
    "typecheck:web": "npm run typecheck -w web",
    "typecheck:mobile": "npm run typecheck -w mobile",
    "dev:web": "npm run dev -w web",
    "dev:mobile": "npm run start -w mobile",
    "check": "npm run typecheck"
  },
  "dependencies": {
    "leaflet": "^1.9.4"
  }
}
